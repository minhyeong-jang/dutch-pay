{
  "name": "@dutch/core",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./settlement": {
      "types": "./dist/settlement/index.d.ts",
      "default": "./src/settlement/index.ts"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/types/index.ts"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "default": "./src/validators/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@dutch/eslint-config": "workspace:*",
    "@dutch/prettier-config": "workspace:*",
    "@dutch/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@dutch/prettier-config"
}
